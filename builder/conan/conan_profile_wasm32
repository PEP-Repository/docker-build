include(./base_conan_profile)

{% set build_os = platform.system() %}

{# Try to find local EMSDK installation #}
{% set emsdk = os.getenv('EMSDK') %}

{% if build_os == 'Windows' -%}
{#
  We need to add extensions (.bat) because otherwise boost says "failed updating 0 target",
  see https://github.com/conan-io/conan-center-index/issues/27607.
#}
{% set script_suffix = '.bat' %}
{%- else -%}
{% set script_suffix = '' %}
{%- endif %}

[settings]
os=Emscripten
arch=wasm
compiler=emcc
compiler.libcxx=libc++
compiler.cppstd=20
compiler.threads=posix

{% if emsdk -%}
{% set compiler, compiler_version, compiler_exe = detect_api.detect_emcc_compiler() %}
compiler.version={{compiler_version}}
{%- endif %}

[conf]
{% if emsdk -%}
tools.build:compiler_executables={'c':'emcc{{script_suffix}}', 'cpp':'em++{{script_suffix}}'}
tools.cmake.cmaketoolchain:user_toolchain=[ '{{ emsdk + '/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake' }}' ]
{%- endif %}

# Use native WASM Exception Handling (and not Emscripten EH): https://emscripten.org/docs/porting/exceptions.html#webassembly-exception-handling-based-support
# Note that this currently uses the well-supported legacy WASM EH, see https://emscripten.org/docs/tools_reference/settings_reference.html#wasm-legacy-exceptions
{% set compile_flags = ['-matomics', '-mbulk-memory', '-fwasm-exceptions'] %}
tools.build:cflags={{compile_flags}}
tools.build:cxxflags={{compile_flags}}

# Make sure to rebuild when we change flags
tools.info.package_id:confs=['tools.build:cflags', 'tools.build:cxxflags', 'tools.build:exelinkflags', 'tools.build:sharedlinkflags']
tools.cmake.cmaketoolchain:generator=Ninja

[tool_requires]
!(cmake/*|ninja/*): ninja/[*]

[buildenv]
{% if emsdk -%}
# Set envvars to use these tools, as the default ones may be incompatible (especially on macOS).
# On Windows, we get an error with emar.bat building OpenSSL that the command line is too long due to CMD restrictions,
# so we call the executables that it would call directly.
AR="{{emsdk+'/upstream/bin/llvm-ar'}}"
NM="{{emsdk+'/upstream/bin/llvm-nm'}}"
RANLIB="{{emsdk+'/upstream/bin/llvm-ranlib'}}"
STRIP="{{emsdk+'/upstream/bin/llvm-strip'}}"
{%- endif %}
